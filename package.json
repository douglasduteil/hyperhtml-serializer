{
  "name": "hyperhtml-serializer",
  "version": "2.1.0",
  "description": "Jest snapshot serializer that beautifies hyperHTML snapshots.",
  "keywords": [
    "jest",
    "serializer",
    "hyperHTML",
    "testing",
    "snapshot"
  ],
  "homepage": "https://github.com/douglasduteil/hyperhtml-serializer#readme",
  "bugs": {
    "url": "https://github.com/douglasduteil/hyperhtml-serializer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/douglasduteil/hyperhtml-serializer.git"
  },
  "license": "WTFPL",
  "author": "Douglas Duteil <douglasduteil@gmail.com> (https://douglasduteil.github.io)",
  "main": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "cover": "jest --coverage",
    "test": "jest --verbose",
    "version": "echo \"Use the release script !\"; exit 1",
    "watch": "jest --watch"
  },
  "jest": {
    "snapshotSerializers": [
      "./index.js"
    ],
    "testEnvironment": "jsdom",
    "testRegex": "/__tests__/.*(test|spec)\\.js$"
  },
  "devDependencies": {
    "hyperhtml": "^2.34.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "peerDependencies": {
    "hyperhtml": ">=2.19"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
