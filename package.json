{
  "name": "hyperhtml-serializer",
  "version": "2.1.0",
  "description": "Jest snapshot serializer that beautifies hyperHTML snapshots.",
  "keywords": [
    "jest",
    "serializer",
    "hyperHTML",
    "testing",
    "snapshot"
  ],
  "homepage": "https://github.com/douglasduteil/hyperhtml-serializer#readme",
  "bugs": {
    "url": "https://github.com/douglasduteil/hyperhtml-serializer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/douglasduteil/hyperhtml-serializer.git"
  },
  "license": "WTFPL",
  "author": "Douglas Duteil <douglasduteil@gmail.com> (https://douglasduteil.github.io)",
  "main": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "cover": "jest --coverage",
    "test": "jest --verbose",
    "version": "echo \"Use the release script !\"; exit 1",
    "watch": "jest --watch"
  },
  "jest": {
    "snapshotSerializers": [
      "./index.js"
    ],
    "testEnvironment": "jsdom",
    "testRegex": "/__tests__/.*(test|spec)\\.js$"
  },
  "devDependencies": {
    "hyperhtml": "^2.34.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "peerDependencies": {
    "hyperhtml": ">=2.19"
  },
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae"
}
